# Required: GitHub OAuth application credentials.
# For local development, set the callback URL to:
# http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Required: a long, random secret used by Auth.js.
AUTH_SECRET=

# Application origin. Change this to the deployed HTTPS URL in production.
AUTH_URL=http://localhost:3000

# Optional: improves GitHub API limits and enables complete statistics.
# Without it, the application falls back to GitHub's public REST API.
GITHUB_TOKEN=

# Optional: Google Search Console HTML verification token.
GOOGLE_SITE_VERIFICATION=
